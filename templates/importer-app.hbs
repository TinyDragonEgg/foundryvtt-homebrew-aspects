{{!-- Aspects of Verun — Importer ApplicationV2 template --}}
<div class="aov-importer-body">

  {{!-- Tab bar --}}
  <nav class="aov-importer-tabs" role="tablist">
    <button type="button"
      class="aov-importer-tab {{#if (eq activeTab 'import')}}active{{/if}}"
      data-action="switchTab" data-tab="import" role="tab">
      <i class="fas fa-file-import"></i> Import
    </button>
    <button type="button"
      class="aov-importer-tab {{#if (eq activeTab 'generate')}}active{{/if}}"
      data-action="switchTab" data-tab="generate" role="tab">
      <i class="fas fa-wand-magic-sparkles"></i> Generate
    </button>
    <button type="button"
      class="aov-importer-tab {{#if (eq activeTab 'log')}}active{{/if}}"
      data-action="switchTab" data-tab="log" role="tab">
      <i class="fas fa-list-ul"></i> Log
      {{#if logLines.length}}<span class="aov-importer-badge">{{logLines.length}}</span>{{/if}}
    </button>
    <button type="button"
      class="aov-importer-tab {{#if (eq activeTab 'settings')}}active{{/if}}"
      data-action="switchTab" data-tab="settings" role="tab">
      <i class="fas fa-cog"></i> Settings
    </button>
  </nav>

  {{!-- ── IMPORT TAB ── --}}
  {{#if (eq activeTab 'import')}}
  <section class="aov-importer-panel" role="tabpanel">

    <div class="aov-importer-toolbar">
      <button type="button" class="aov-importer-btn" data-action="openFilePicker">
        <i class="fas fa-folder-open"></i> Load File
      </button>
      <span class="aov-importer-label">or paste JSON below:</span>
    </div>

    <textarea
      class="aov-importer-json-input"
      placeholder='Paste Foundry Item JSON or AI-format JSON here…&#10;&#10;Single item or array of items.'
      spellcheck="false"
      rows="12"></textarea>

    <div class="aov-importer-parse-row">
      <button type="button" class="aov-importer-btn aov-btn-primary" data-action="parseJson">
        <i class="fas fa-search"></i> Parse
      </button>

      {{#if hasDocs}}
      <span class="aov-importer-status aov-status-ok">
        <i class="fas fa-check-circle"></i> {{docCount}} item(s) ready
      </span>
      {{/if}}

      {{#if hasErrors}}
      <span class="aov-importer-status aov-status-error">
        <i class="fas fa-exclamation-triangle"></i> {{parseErrors.length}} error(s)
      </span>
      {{/if}}
    </div>

    {{#if parseErrors.length}}
    <ul class="aov-importer-error-list">
      {{#each parseErrors}}
      <li><i class="fas fa-times-circle"></i> {{this}}</li>
      {{/each}}
    </ul>
    {{/if}}

    {{#if hasDocs}}
    <details class="aov-importer-preview">
      <summary>Preview ({{docCount}} item{{#if (gt docCount 1)}}s{{/if}})</summary>
      <ul class="aov-importer-preview-list">
        {{#each parsedDocs}}
        <li>
          <strong>{{this.converted.name}}</strong>
          <span class="aov-importer-meta">{{this.converted.type}}</span>
          {{#if this.isAiFormat}}<em class="aov-importer-tag">AI format</em>{{/if}}
        </li>
        {{/each}}
      </ul>
    </details>

    <div class="aov-importer-import-row">
      <label class="aov-importer-check-label">
        <input type="checkbox" class="aov-overwrite-check" {{#if settings.overwrite}}checked{{/if}}>
        Overwrite existing items
      </label>

      <button type="button"
        class="aov-importer-btn aov-btn-import {{#if importing}}aov-btn-disabled{{/if}}"
        data-action="startImport"
        {{#if importing}}disabled{{/if}}>
        {{#if importing}}
          <i class="fas fa-spinner fa-spin"></i> Importing… ({{importProgress}}%)
        {{else}}
          <i class="fas fa-cloud-upload-alt"></i> Import {{docCount}} Item{{#if (gt docCount 1)}}s{{/if}}
        {{/if}}
      </button>
    </div>

    {{#if importing}}
    <div class="aov-importer-progress-bar">
      <div class="aov-importer-progress-fill" style="width: {{importProgress}}%"></div>
    </div>
    {{/if}}

    {{/if}}{{!-- hasDocs --}}
  </section>
  {{/if}}

  {{!-- ── GENERATE TAB ── --}}
  {{#if (eq activeTab 'generate')}}
  <section class="aov-importer-panel" role="tabpanel">

    {{#unless hasApiKey}}
    <div class="aov-generate-warning">
      <i class="fas fa-exclamation-triangle"></i>
      No API key set. Add your Anthropic API key in
      <strong>Module Settings → Aspects of Verun → Claude API Key</strong>.
    </div>
    {{/unless}}

    <label class="aov-generate-label">
      Describe the item(s) you want:
      <span class="aov-generate-model-hint">using {{modelLabel}}</span>
    </label>

    <textarea
      class="aov-generate-prompt"
      placeholder="One item per paragraph — separate with a blank line:&#10;&#10;A rare shortsword that crackles with lightning and lets the wielder call down a bolt once per day&#10;&#10;An uncommon healing potion that restores 2d4+2 hit points&#10;&#10;A legendary amulet that lets the wearer cast Wish once, then crumbles to dust&#10;&#10;Or paste the full 25-prompt stress-test list all at once."
      spellcheck="true"
      rows="10"></textarea>
    <div class="aov-generate-meta-row">
      <span class="aov-generate-item-count"></span>
      <span class="aov-importer-label">Separate items with a blank line · single item uses ×N count</span>
    </div>

    {{#if generateError}}
    <div class="aov-generate-error">
      <i class="fas fa-times-circle"></i> {{generateError}}
    </div>
    {{/if}}

    <div class="aov-generate-row">
      <button type="button"
        class="aov-importer-btn aov-btn-generate {{#if generating}}aov-btn-disabled{{/if}}"
        data-action="generate"
        {{#if generating}}disabled{{/if}}
        {{#unless hasApiKey}}disabled{{/unless}}>
        {{#if generating}}
          <i class="fas fa-spinner fa-spin"></i> Generating…
        {{else}}
          <i class="fas fa-wand-magic-sparkles"></i> Generate
        {{/if}}
      </button>
      <label class="aov-generate-count-label">
        <span>×</span>
        <input type="number" class="aov-generate-count" min="1" max="10" value="{{generateCount}}"
          {{#if generating}}disabled{{/if}}>
      </label>
      <span class="aov-importer-label">Items appear on Import tab ready to review.</span>
    </div>

  </section>
  {{/if}}

  {{!-- ── LOG TAB ── --}}
  {{#if (eq activeTab 'log')}}
  <section class="aov-importer-panel" role="tabpanel">
    <div class="aov-importer-log-toolbar">
      <button type="button" class="aov-importer-btn aov-btn-sm" data-action="clearLog">
        <i class="fas fa-trash"></i> Clear
      </button>
      <span class="aov-importer-label">{{logLines.length}} line(s)</span>
    </div>
    <pre class="aov-importer-log-output">{{#each logLines}}{{this}}&#10;{{/each}}</pre>
  </section>
  {{/if}}

  {{!-- ── SETTINGS TAB ── --}}
  {{#if (eq activeTab 'settings')}}
  <section class="aov-importer-panel aov-importer-settings-panel" role="tabpanel">
    <p class="aov-importer-settings-hint">
      These settings mirror the module settings in the Foundry settings menu.
    </p>
    <dl class="aov-importer-settings-list">
      <dt>Auto-resolve images</dt>
      <dd>{{#if settings.autoResolveImages}}Enabled{{else}}Disabled{{/if}}</dd>
      <dt>Auto-create folders</dt>
      <dd>{{#if settings.autoCreateFolders}}Enabled{{else}}Disabled{{/if}}</dd>
      <dt>Backup on overwrite</dt>
      <dd>{{#if settings.overwrite}}Enabled{{else}}Disabled{{/if}}</dd>
      <dt>Claude model</dt>
      <dd>{{modelLabel}}</dd>
      <dt>Claude API key</dt>
      <dd>{{#if hasApiKey}}Set{{else}}<strong style="color:#8b1a1a">Not set</strong>{{/if}}</dd>
    </dl>
    <p class="aov-importer-settings-hint">
      Open <strong>Game Settings → Module Settings → Aspects of Verun</strong> to change these.
    </p>
  </section>
  {{/if}}

</div>
